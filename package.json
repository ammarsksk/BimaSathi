{
    "name": "bimasathi",
    "version": "1.0.0",
    "description": "BimaSathi — WhatsApp-first, voice-enabled AI crop insurance claim assistant for Indian farmers",
    "private": true,
    "scripts": {
        "lint": "eslint src/",
        "validate": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sam.ps1 validate",
        "build": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sam.ps1 build",
        "deploy:guided": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sam.ps1 deploy --guided --config-env default",
        "deploy": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sam.ps1 deploy --config-env default",
        "sync": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sam.ps1 sync --watch --config-env default",
        "deploy:watch": "powershell -ExecutionPolicy Bypass -File .\\scripts\\deploy-watch.ps1"
    },
    "dependencies": {
        "@aws-sdk/client-bedrock-runtime": "^3.500.0",
        "@aws-sdk/client-cognito-identity-provider": "^3.500.0",
        "@aws-sdk/client-dynamodb": "^3.500.0",
        "@aws-sdk/client-eventbridge": "^3.500.0",
        "@aws-sdk/client-lambda": "^3.500.0",
        "@aws-sdk/client-polly": "^3.500.0",
        "@aws-sdk/client-rekognition": "^3.500.0",
        "@aws-sdk/client-s3": "^3.500.0",
        "@aws-sdk/client-sfn": "^3.500.0",
        "@aws-sdk/client-textract": "^3.500.0",
        "@aws-sdk/client-transcribe": "^3.500.0",
        "@aws-sdk/lib-dynamodb": "^3.500.0",
        "@aws-sdk/s3-request-presigner": "^3.500.0",
        "axios": "^1.6.0",
        "crypto": "^1.0.1",
        "exif-reader": "^2.0.0",
        "pdf-lib": "^1.17.1",
        "rewire": "^9.0.1",
        "sharp": "^0.33.0",
        "twilio": "^4.20.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "eslint": "^8.56.0"
    }
}
