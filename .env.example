# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=

# Twilio Dashboard Authentication
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS Region
AWS_REGION=ap-south-1

# DynamoDB Table Names
USERS_TABLE=bimasathi-users
CLAIMS_TABLE=bimasathi-claims
CONVERSATIONS_TABLE=bimasathi-conversations
DEADLINES_TABLE=bimasathi-deadlines
AUDIT_LOG_TABLE=bimasathi-audit-log
CONSENT_TABLE=bimasathi-consent

# S3
EVIDENCE_BUCKET=

# Amazon Bedrock
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_REGION=us-east-1

# Amazon Polly / Transcribe
POLLY_REGION=ap-south-1
TRANSCRIBE_REGION=ap-south-1

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Optional runtime override
NODE_ENV=production
